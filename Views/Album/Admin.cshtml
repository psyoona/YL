@{
	Layout = "~/Views/Shared/_AlbumLayout.cshtml";
	ViewBag.PageTitle = "웹 앨범 - 관리";
}

<div class="admin-wrapper">
	<header class="admin-header">
		<a href="/Album/Index" class="admin-back">
			<i class="fas fa-arrow-left"></i>
		</a>
		<h1><i class="fas fa-cog me-2"></i>관리</h1>
		<div class="admin-user">
			<span>@ViewBag.UserName</span>
		</div>
	</header>

	<div class="admin-content">
		<!-- 역할 관리 -->
		<section class="admin-section">
			<div class="section-header">
				<h2><i class="fas fa-user-tag me-2"></i>역할 관리</h2>
			</div>
			<div class="section-body">
				<div class="add-form">
					<input type="text" id="newRoleName" placeholder="새 역할명 입력" maxlength="100" />
					<button id="btnAddRole" class="btn-add"><i class="fas fa-plus me-1"></i>추가</button>
				</div>
				<div class="data-list" id="roleList">
					<div class="loading-text">로딩 중...</div>
				</div>
			</div>
		</section>

		<!-- 사용자 권한 관리 -->
		<section class="admin-section">
			<div class="section-header">
				<h2><i class="fas fa-users me-2"></i>사용자 권한 관리</h2>
			</div>
			<div class="section-body">
				<div class="add-form">
					<select id="assignUserSelect">
						<option value="">사용자 선택</option>
					</select>
					<select id="assignRoleSelect">
						<option value="">역할 선택</option>
					</select>
					<button id="btnAssignRole" class="btn-add"><i class="fas fa-plus me-1"></i>부여</button>
				</div>
				<div class="data-list" id="userRoleList">
					<div class="loading-text">로딩 중...</div>
				</div>
			</div>
		</section>

		<!-- 앨범 접근 관리 -->
		<section class="admin-section">
			<div class="section-header">
				<h2><i class="fas fa-lock me-2"></i>앨범 접근 관리</h2>
			</div>
			<div class="section-body">
				<p class="section-note">접근 규칙이 없는 앨범은 모든 로그인 사용자가 접근할 수 있습니다.</p>
				<div class="add-form">
					<select id="accessAlbumSelect">
						<option value="">앨범 선택</option>
					</select>
					<select id="accessRoleSelect">
						<option value="">역할 선택</option>
					</select>
					<button id="btnAddAccess" class="btn-add"><i class="fas fa-plus me-1"></i>추가</button>
				</div>
				<div class="data-list" id="albumAccessList">
					<div class="loading-text">로딩 중...</div>
				</div>
			</div>
		</section>
	</div>
</div>

<script defer src="~/js/Album/admin.js?v=@ViewBag.Cacheversion"></script>
