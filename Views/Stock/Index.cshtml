@{
	Layout = "~/Views/Shared/_StockLayout.cshtml";
	ViewBag.PageTitle = "Stock Manager";
}

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<div class="stock-wrapper">
	<!-- 사이드바 -->
	<aside class="sidebar" id="sidebar">
		<div class="sidebar-header">
			<div class="sidebar-logo">
				<i class="fas fa-chart-line"></i>
				<span>Stock Manager</span>
			</div>
			<button class="sidebar-close" id="sidebarClose">
				<i class="fas fa-times"></i>
			</button>
		</div>

		<div class="sidebar-user">
			<div class="user-avatar">
				<i class="fas fa-user"></i>
			</div>
			<div class="user-info">
				<span class="user-name">@ViewBag.UserName</span>
				<span class="user-status">접속 중</span>
			</div>
		</div>

		<nav class="sidebar-nav">
			<ul class="nav-menu">
				<li>
					<a href="#" class="nav-item active" data-page="stocks">
						<i class="fas fa-list-ul"></i>
						<span>종목 관리</span>
					</a>
				</li>
				<li>
					<a href="#" class="nav-item" data-page="holdings">
						<i class="fas fa-wallet"></i>
						<span>보유 종목</span>
					</a>
				</li>
				<li>
					<a href="#" class="nav-item" data-page="orders">
						<i class="fas fa-exchange-alt"></i>
						<span>주문 내역</span>
					</a>
				</li>
				<li>
					<a href="#" class="nav-item" data-page="logs">
						<i class="fas fa-scroll"></i>
						<span>거래 로그</span>
					</a>
				</li>
				<li class="nav-divider"></li>
				<li>
					<a href="#" class="nav-item" data-page="trader">
						<i class="fas fa-robot"></i>
						<span>자동매매 제어</span>
					</a>
				</li>
				<li>
					<a href="#" class="nav-item" data-page="backtest">
						<i class="fas fa-flask"></i>
						<span>백테스트</span>
					</a>
				</li>
				<li>
					<a href="#" class="nav-item" data-page="collect">
						<i class="fas fa-database"></i>
						<span>일봉 수집</span>
					</a>
				</li>
			</ul>
		</nav>

		<div class="sidebar-system-info">
			<div class="system-info-title">
				<i class="fas fa-info-circle"></i>
				<span>System Info</span>
			</div>
			<div class="system-info-item">
				<span class="system-info-label">Version</span>
				<span class="system-info-value">v@(ViewBag.CacheVersion)</span>
			</div>
		</div>

		<div class="sidebar-footer">
			<a href="#" id="btnLogout" class="btn-logout">
				<i class="fas fa-sign-out-alt me-2"></i>로그아웃
			</a>
		</div>
	</aside>

	<!-- 메인 콘텐츠 -->
	<main class="main-content" id="mainContent">
		<header class="top-bar">
			<button class="menu-toggle" id="menuToggle">
				<i class="fas fa-bars"></i>
			</button>
			<h2 class="page-title" id="pageTitle">종목 관리</h2>
		</header>

		<!-- 종목 관리 -->
		<div class="page-content" id="page-stocks">
			<div class="content-header">
				<div class="content-header-left">
					<span class="data-count" id="stockCount"></span>
				</div>
				<div class="content-header-right">
					<button class="btn-primary-action" id="btnAddStock">
						<i class="fas fa-plus me-1"></i>종목 추가
					</button>
				</div>
			</div>
			<div class="table-wrapper">
				<table class="data-table" id="stockTable">
					<thead>
						<tr>
							<th>종목코드</th>
							<th>종목명</th>
							<th>시장</th>
							<th>상태</th>
							<th>감시</th>
							<th>관리</th>
						</tr>
					</thead>
					<tbody id="stockTableBody"></tbody>
				</table>
				<div class="empty-state" id="stockEmpty">
					<i class="fas fa-inbox"></i>
					<p>등록된 종목이 없습니다</p>
				</div>
			</div>
		</div>

		<!-- 보유 종목 -->
		<div class="page-content" id="page-holdings" style="display:none;">
			<div class="content-header">
				<div class="content-header-left">
					<span class="data-count" id="holdingCount"></span>
				</div>
			</div>
			<div class="table-wrapper">
				<table class="data-table" id="holdingTable">
					<thead>
						<tr>
							<th>종목코드</th>
							<th>종목명</th>
							<th>수량</th>
							<th>평균단가</th>
							<th>현재가</th>
							<th>수익률</th>
						</tr>
					</thead>
					<tbody id="holdingTableBody"></tbody>
				</table>
				<div class="empty-state" id="holdingEmpty">
					<i class="fas fa-inbox"></i>
					<p>보유 종목이 없습니다</p>
				</div>
			</div>
		</div>

		<!-- 주문 내역 -->
		<div class="page-content" id="page-orders" style="display:none;">
			<div class="content-header">
				<div class="content-header-left">
					<span class="data-count" id="orderCount"></span>
				</div>
			</div>
			<div class="table-wrapper">
				<table class="data-table" id="orderTable">
					<thead>
						<tr>
							<th>주문번호</th>
							<th>종목</th>
							<th>구분</th>
							<th>주문가</th>
							<th>주문수량</th>
							<th>체결수량</th>
							<th>상태</th>
							<th>일시</th>
						</tr>
					</thead>
					<tbody id="orderTableBody"></tbody>
				</table>
				<div class="empty-state" id="orderEmpty">
					<i class="fas fa-inbox"></i>
					<p>주문 내역이 없습니다</p>
				</div>
			</div>
		</div>

		<!-- 거래 로그 -->
		<div class="page-content" id="page-logs" style="display:none;">
			<div class="content-header">
				<div class="content-header-left">
					<span class="data-count" id="logCount"></span>
				</div>
			</div>
			<div class="table-wrapper">
				<table class="data-table" id="logTable">
					<thead>
						<tr>
							<th>레벨</th>
							<th>메시지</th>
							<th>종목코드</th>
							<th>일시</th>
						</tr>
					</thead>
					<tbody id="logTableBody"></tbody>
				</table>
				<div class="empty-state" id="logEmpty">
					<i class="fas fa-inbox"></i>
					<p>거래 로그가 없습니다</p>
				</div>
			</div>
		</div>

		<!-- 자동매매 제어 -->
		<div class="page-content" id="page-trader" style="display:none;">
			<div class="trader-control">
				<!-- 상태 카드 -->
				<div class="trader-status-card" id="traderStatusCard">
					<div class="trader-status-header">
						<div class="trader-status-indicator" id="traderIndicator">
							<span class="status-dot" id="statusDot"></span>
							<span class="status-text" id="statusText">확인 중...</span>
						</div>
						<div class="trader-actions">
							<button class="btn-trader btn-trader-start" id="btnStartTrader" disabled>
								<i class="fas fa-play"></i>
								<span>실행</span>
							</button>
							<button class="btn-trader btn-trader-stop" id="btnStopTrader" disabled>
								<i class="fas fa-stop"></i>
								<span>중지</span>
							</button>
						</div>
					</div>
					<div class="trader-info-grid">
						<div class="trader-info-item">
							<span class="info-label">PID</span>
							<span class="info-value" id="traderPid">-</span>
						</div>
						<div class="trader-info-item">
							<span class="info-label">시작 시간</span>
							<span class="info-value" id="traderStartedAt">-</span>
						</div>
						<div class="trader-info-item">
							<span class="info-label">실행 시간</span>
							<span class="info-value" id="traderUptime">-</span>
						</div>
						<div class="trader-info-item">
							<span class="info-label">실행 경로</span>
							<span class="info-value info-path" id="traderExePath">-</span>
						</div>
					</div>
				</div>

				<!-- 콘솔 로그 -->
				<div class="trader-console">
					<div class="console-header">
						<span><i class="fas fa-terminal me-2"></i>콘솔 출력</span>
						<button class="btn-console-refresh" id="btnRefreshLogs" title="새로고침">
							<i class="fas fa-sync-alt"></i>
						</button>
					</div>
					<div class="console-body" id="traderConsole">
						<div class="console-empty">로그가 없습니다</div>
					</div>
				</div>
			</div>
		</div>
		<!-- 백테스트 -->
		<div class="page-content" id="page-backtest" style="display:none;">
			<div class="backtest-container">
				<!-- 설정 카드 -->
				<div class="backtest-config-card">
					<h3 class="backtest-section-title"><i class="fas fa-cog me-2"></i>백테스트 설정</h3>
					<div class="backtest-form">
						<div class="backtest-form-row">
							<div class="backtest-form-group">
								<label for="btStartDate">시작일</label>
								<input type="date" id="btStartDate" />
							</div>
							<div class="backtest-form-group">
								<label for="btEndDate">종료일</label>
								<input type="date" id="btEndDate" />
							</div>
							<div class="backtest-form-group">
								<label for="btCapital">초기 자본금</label>
								<input type="number" id="btCapital" value="10000000" min="100000" step="1000000" />
							</div>
						</div>
						<div class="backtest-form-actions">
							<button class="btn-primary-action" id="btnRunBacktest">
								<i class="fas fa-play me-1"></i>백테스트 실행
							</button>
						</div>
					</div>
				</div>

				<!-- 실행 중 표시 -->
				<div class="backtest-loading" id="backtestLoading" style="display:none;">
					<div class="backtest-spinner"></div>
					<p>백테스트 실행 중... (최대 5분 소요)</p>
				</div>

				<!-- 결과 영역 -->
				<div id="backtestResults" style="display:none;">
					<!-- 요약 카드 -->
					<div class="backtest-summary">
						<h3 class="backtest-section-title"><i class="fas fa-chart-bar me-2"></i>결과 요약</h3>
						<div class="backtest-metrics">
							<div class="backtest-metric">
								<span class="metric-label">총 수익률</span>
								<span class="metric-value" id="btTotalReturn">-</span>
							</div>
							<div class="backtest-metric">
								<span class="metric-label">최종 자본</span>
								<span class="metric-value" id="btFinalCapital">-</span>
							</div>
							<div class="backtest-metric">
								<span class="metric-label">승률</span>
								<span class="metric-value" id="btWinRate">-</span>
							</div>
							<div class="backtest-metric">
								<span class="metric-label">총 거래</span>
								<span class="metric-value" id="btTotalTrades">-</span>
							</div>
							<div class="backtest-metric">
								<span class="metric-label">MDD</span>
								<span class="metric-value" id="btMDD">-</span>
							</div>
							<div class="backtest-metric">
								<span class="metric-label">Profit Factor</span>
								<span class="metric-value" id="btProfitFactor">-</span>
							</div>
							<div class="backtest-metric">
								<span class="metric-label">평균 수익</span>
								<span class="metric-value" id="btAvgWin">-</span>
							</div>
							<div class="backtest-metric">
								<span class="metric-label">평균 손실</span>
								<span class="metric-value" id="btAvgLoss">-</span>
							</div>
						</div>
					</div>

					<!-- 거래 내역 -->
					<div class="backtest-trades">
						<h3 class="backtest-section-title"><i class="fas fa-list me-2"></i>거래 내역</h3>
						<div class="table-wrapper">
							<table class="data-table" id="btTradeTable">
								<thead>
									<tr>
										<th>종목</th>
										<th>매수일</th>
										<th>매수가</th>
										<th>수량</th>
										<th>매도일</th>
										<th>매도가</th>
										<th>수익률</th>
										<th>사유</th>
									</tr>
								</thead>
								<tbody id="btTradeTableBody"></tbody>
							</table>
						</div>
					</div>

					<!-- 실행 로그 -->
					<div class="backtest-log-section">
						<h3 class="backtest-section-title">
							<i class="fas fa-terminal me-2"></i>실행 로그
							<button class="btn-console-refresh" id="btnToggleBtLog" title="접기/펼치기">
								<i class="fas fa-chevron-down"></i>
							</button>
						</h3>
						<div class="console-body backtest-log-body" id="btLogBody" style="display:none;"></div>
					</div>
				</div>
			</div>
		</div>
		<!-- 일봉 수집 -->
		<div class="page-content" id="page-collect" style="display:none;">
			<div class="backtest-container">
				<div class="backtest-config-card">
					<h3 class="backtest-section-title"><i class="fas fa-database me-2"></i>일봉 데이터 수집</h3>
					<p class="collect-description">
						한국투자증권 KIS API에서 감시 종목의 일봉(OHLCV) 데이터를 수집합니다.<br>
						백테스트를 실행하려면 먼저 해당 기간의 일봉 데이터가 필요합니다.
					</p>
					<div class="backtest-form">
						<div class="backtest-form-row" style="grid-template-columns: 1fr 1fr;">
							<div class="backtest-form-group">
								<label for="collectStartDate">시작일</label>
								<input type="date" id="collectStartDate" />
							</div>
							<div class="backtest-form-group">
								<label for="collectEndDate">종료일</label>
								<input type="date" id="collectEndDate" />
							</div>
						</div>
						<div class="backtest-form-actions">
							<button class="btn-primary-action" id="btnCollectDailyPrices">
								<i class="fas fa-download me-1"></i>수집 시작
							</button>
						</div>
					</div>
				</div>

				<!-- 수집 중 표시 -->
				<div class="backtest-loading" id="collectLoading" style="display:none;">
					<div class="backtest-spinner"></div>
					<p>일봉 데이터 수집 중... (종목 수에 따라 최대 10분 소요)</p>
				</div>

				<!-- 수집 결과 -->
				<div id="collectResults" style="display:none;">
					<div class="backtest-summary">
						<h3 class="backtest-section-title"><i class="fas fa-check-circle me-2"></i>수집 결과</h3>
						<div class="backtest-metrics" style="grid-template-columns: repeat(2, 1fr);">
							<div class="backtest-metric">
								<span class="metric-label">수집 종목 수</span>
								<span class="metric-value" id="collectTotalStocks">-</span>
							</div>
							<div class="backtest-metric">
								<span class="metric-label">저장 건수</span>
								<span class="metric-value" id="collectTotalRecords">-</span>
							</div>
						</div>
						<div id="collectMessage" class="collect-message"></div>
						<div id="collectErrors" class="collect-errors" style="display:none;"></div>
					</div>
				</div>
			</div>
		</div>
	</main>
</div>

<!-- 종목 추가/수정 모달 -->
<div class="stock-modal" id="stockModal" style="display:none;">
	<div class="stock-modal-box">
		<h3 id="stockModalTitle"><i class="fas fa-plus-circle me-2"></i>종목 추가</h3>
		<div class="modal-input">
			<label for="modalStockCode">종목코드</label>
			<input type="text" id="modalStockCode" placeholder="예: 005930" maxlength="20" />
		</div>
		<div class="modal-input">
			<label for="modalStockName">종목명</label>
			<input type="text" id="modalStockName" placeholder="예: 삼성전자" maxlength="100" />
		</div>
		<div class="modal-input">
			<label for="modalMarketType">시장구분</label>
			<select id="modalMarketType">
				<option value="KOSPI">KOSPI</option>
				<option value="KOSDAQ">KOSDAQ</option>
			</select>
		</div>
		<div class="modal-input modal-checkbox-group" id="stockEditFields" style="display:none;">
			<label class="checkbox-label">
				<input type="checkbox" id="modalIsActive" checked />
				<span>활성 상태</span>
			</label>
			<label class="checkbox-label">
				<input type="checkbox" id="modalIsWatchList" />
				<span>감시 종목</span>
			</label>
		</div>
		<div class="modal-actions">
			<button class="btn-modal-cancel" id="stockModalCancel">취소</button>
			<button class="btn-modal-confirm" id="stockModalConfirm">저장</button>
		</div>
	</div>
</div>

<!-- 삭제 확인 모달 -->
<div class="stock-modal" id="deleteModal" style="display:none;">
	<div class="stock-modal-box">
		<i class="fas fa-exclamation-triangle warning-icon"></i>
		<p id="deleteMessage">정말 삭제하시겠습니까?</p>
		<div class="modal-actions">
			<button class="btn-modal-cancel" id="deleteModalCancel">취소</button>
			<button class="btn-modal-delete" id="deleteModalConfirm">삭제</button>
		</div>
	</div>
</div>

<!-- 로그아웃 확인 모달 -->
<div class="stock-modal" id="logoutModal" style="display:none;">
	<div class="stock-modal-box">
		<i class="fas fa-sign-out-alt" style="font-size: 48px; color: var(--primary-light); margin-bottom: 16px;"></i>
		<p>로그아웃 하시겠습니까?</p>
		<div class="modal-actions">
			<button class="btn-modal-cancel" id="logoutCancel">취소</button>
			<button class="btn-modal-confirm" id="logoutConfirm">로그아웃</button>
		</div>
	</div>
</div>

<!-- 자동매매 실행 확인 모달 -->
<div class="stock-modal" id="traderStartModal" style="display:none;">
	<div class="stock-modal-box">
		<i class="fas fa-play-circle" style="font-size: 48px; color: var(--primary-light); margin-bottom: 16px;"></i>
		<p>자동매매 프로그램을 실행하시겠습니까?</p>
		<div class="modal-actions">
			<button class="btn-modal-cancel" id="traderStartCancel">취소</button>
			<button class="btn-modal-confirm" id="traderStartConfirm">실행</button>
		</div>
	</div>
</div>

<!-- 자동매매 중지 확인 모달 -->
<div class="stock-modal" id="traderStopModal" style="display:none;">
	<div class="stock-modal-box">
		<i class="fas fa-exclamation-triangle warning-icon"></i>
		<p>자동매매 프로그램을 중지하시겠습니까?</p>
		<p style="font-size: 13px; color: var(--text-muted); margin-top: 8px;">진행 중인 매매가 있을 경우 중단됩니다.</p>
		<div class="modal-actions">
			<button class="btn-modal-cancel" id="traderStopCancel">취소</button>
			<button class="btn-modal-delete" id="traderStopConfirm">중지</button>
		</div>
	</div>
</div>

<!-- 범용 알림/확인 모달 -->
<div class="stock-modal" id="commonModal" style="display:none;">
	<div class="stock-modal-box">
		<i id="commonModalIcon" class="fas fa-info-circle" style="font-size: 48px; color: var(--primary-light); margin-bottom: 16px;"></i>
		<p id="commonModalMessage"></p>
		<p id="commonModalSub" style="font-size: 13px; color: var(--text-muted); margin-top: 8px; display:none;"></p>
		<div class="modal-actions">
