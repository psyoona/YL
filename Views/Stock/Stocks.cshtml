<!-- 종목 관리 -->
<div class="page-content" id="page-stocks">
	<div class="content-header">
		<div class="content-header-left">
			<span class="data-count" id="stockCount"></span>
		</div>
		<div class="content-header-right">
			<button class="btn-secondary-action" id="btnRefreshPrices">
				<i class="fas fa-sync-alt me-1"></i>현재가 조회
			</button>
			<button class="btn-primary-action" id="btnAddStock">
				<i class="fas fa-plus me-1"></i>종목 추가
			</button>
		</div>
	</div>
	<div class="table-wrapper">
		<table class="data-table" id="stockTable">
			<thead>
				<tr>
					<th>종목코드</th>
					<th>종목명</th>
					<th>시장</th>
					<th>현재가</th>
					<th>전일비</th>
					<th>상태</th>
					<th>감시</th>
					<th>관리</th>
				</tr>
			</thead>
			<tbody id="stockTableBody"></tbody>
		</table>
		<div class="empty-state" id="stockEmpty">
			<i class="fas fa-inbox"></i>
			<p>등록된 종목이 없습니다</p>
		</div>
	</div>
</div>

<!-- 종목 추가/수정 모달 -->
<div class="stock-modal" id="stockModal" style="display:none;">
	<div class="stock-modal-box">
		<h3 id="stockModalTitle"><i class="fas fa-plus-circle me-2"></i>종목 추가</h3>
		<div class="modal-input">
			<label for="modalStockCode">종목코드</label>
			<input type="text" id="modalStockCode" placeholder="예: 005930" maxlength="20" />
		</div>
		<div class="modal-input">
			<label for="modalStockName">종목명</label>
			<input type="text" id="modalStockName" placeholder="예: 삼성전자" maxlength="100" />
		</div>
		<div class="modal-input">
			<label for="modalMarketType">시장구분</label>
			<select id="modalMarketType">
				<option value="KOSPI">KOSPI</option>
				<option value="KOSDAQ">KOSDAQ</option>
			</select>
		</div>
		<div class="modal-input modal-checkbox-group" id="stockEditFields" style="display:none;">
			<label class="checkbox-label">
				<input type="checkbox" id="modalIsActive" checked />
				<span>활성 상태</span>
			</label>
			<label class="checkbox-label">
				<input type="checkbox" id="modalIsWatchList" />
				<span>감시 종목</span>
			</label>
		</div>
		<div class="modal-actions">
			<button class="btn-modal-cancel" id="stockModalCancel">취소</button>
			<button class="btn-modal-confirm" id="stockModalConfirm">저장</button>
		</div>
	</div>
</div>

<script defer src="/js/Stock/stocks.js?v=@ViewBag.CacheVersion"></script>
