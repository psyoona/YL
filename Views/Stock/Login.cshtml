@{
	Layout = "~/Views/Shared/_StockLayout.cshtml";
	ViewBag.PageTitle = "Stock Manager - 로그인";
}

<div class="login-wrapper">
	<div class="login-container">
		<div class="login-header">
			<div class="login-icon">
				<i class="fas fa-chart-line"></i>
			</div>
			<h1 class="login-title">Stock Manager</h1>
			<p class="login-subtitle">주식 종목 관리 시스템</p>
		</div>

		<div class="login-form">
			<div class="input-group-custom">
				<label for="loginId">
					<i class="fas fa-user"></i> 아이디
				</label>
				<input
					id="loginId"
					type="text"
					class="form-input"
					placeholder="아이디를 입력하세요"
					maxlength="50"
					autocomplete="username"
				/>
			</div>

			<div class="input-group-custom">
				<label for="password">
					<i class="fas fa-lock"></i> 비밀번호
				</label>
				<input
					id="password"
					type="password"
					class="form-input"
					placeholder="비밀번호를 입력하세요"
					maxlength="20"
					autocomplete="current-password"
				/>
			</div>

			<button id="btnLogin" class="btn-login" type="button">
				<i class="fas fa-sign-in-alt me-2"></i>로그인
			</button>

			<div id="loginMessage" class="login-message" style="display: none;"></div>
		</div>
	</div>
</div>

<script defer src="~/js/Stock/login.js?v=@ViewBag.CacheVersion"></script>
