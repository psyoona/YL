<!-- 거래 로그 -->
<div class="page-content" id="page-logs" >
	<div class="content-header">
		<div class="content-header-left">
			<span class="data-count" id="logCount"></span>
		</div>
	</div>
	<div class="table-wrapper">
		<table class="data-table" id="logTable">
			<thead>
				<tr>
					<th>레벨</th>
					<th>메시지</th>
					<th>종목코드</th>
					<th>일시</th>
				</tr>
			</thead>
			<tbody id="logTableBody"></tbody>
		</table>
		<div class="empty-state" id="logEmpty">
			<i class="fas fa-inbox"></i>
			<p>거래 로그가 없습니다</p>
		</div>
	</div>
</div>

<script defer src="/js/Stock/logs.js?v=@ViewBag.CacheVersion"></script>
