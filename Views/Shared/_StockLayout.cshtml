<!DOCTYPE html>
<html lang="ko">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css?v=@ViewBag.CacheVersion" />
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css?v=@ViewBag.CacheVersion" />
	<link rel="stylesheet" href="~/css/Stock/stock.css?v=@ViewBag.CacheVersion" />

	<script defer src="~/lib/fontawesome/js/all.min.js?v=@ViewBag.CacheVersion"></script>
	<script defer src="~/lib/jquery/dist/jquery.min.js?v=@ViewBag.CacheVersion"></script>
	<script defer src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js?v=@ViewBag.CacheVersion"></script>
	<script defer src="~/lib/security/sha512.min.js?v=@ViewBag.CacheVersion"></script>
	<script defer src="~/js/Common/screenUtility.js?v=@ViewBag.CacheVersion"></script>
	<script defer src="~/js/Common/stringUtility.js?v=@ViewBag.CacheVersion"></script>
	<script defer src="~/js/Common/format.js?v=@ViewBag.CacheVersion"></script>
	<script defer src="~/js/Common/webServer.js?v=@ViewBag.CacheVersion"></script>
	<script defer src="~/js/Stock/stockLayout.js?v=@ViewBag.CacheVersion"></script>

	<title>@ViewBag.PageTitle</title>
</head>
<body>
	<div class="sidebar-overlay" id="sidebarOverlay"></div>

	<div class="stock-wrapper">
		<!-- 사이드바 -->
		<aside class="sidebar" id="sidebar">
			<div class="sidebar-header">
				<div class="sidebar-logo">
					<i class="fas fa-chart-line"></i>
					<span>Stock Manager</span>
				</div>
				<button class="sidebar-close" id="sidebarClose">
					<i class="fas fa-times"></i>
				</button>
			</div>

			<div class="sidebar-user">
				<div class="user-avatar">
					<i class="fas fa-user"></i>
				</div>
				<div class="user-info">
					<span class="user-name">@ViewBag.UserName</span>
					<span class="user-status">접속 중</span>
				</div>
			</div>

			@{
				var currentPage = (ViewBag.CurrentPage as string ?? "Stocks").ToLower();
			}
			<nav class="sidebar-nav">
				<ul class="nav-menu">
					<li><a href="/Stock/Stocks" class="nav-item @(currentPage == "stocks" ? "active" : "")"><i class="fas fa-list-ul"></i><span>종목 관리</span></a></li>
					<li><a href="/Stock/Holdings" class="nav-item @(currentPage == "holdings" ? "active" : "")"><i class="fas fa-wallet"></i><span>보유 종목</span></a></li>
					<li><a href="/Stock/Orders" class="nav-item @(currentPage == "orders" ? "active" : "")"><i class="fas fa-exchange-alt"></i><span>주문 내역</span></a></li>
					<li><a href="/Stock/TradeLogs" class="nav-item @(currentPage == "tradelogs" ? "active" : "")"><i class="fas fa-scroll"></i><span>거래 로그</span></a></li>
					<li class="nav-divider"></li>
					<li><a href="/Stock/AutoTrading" class="nav-item @(currentPage == "autotrading" ? "active" : "")"><i class="fas fa-robot"></i><span>자동매매 제어</span></a></li>
					<li><a href="/Stock/Backtest" class="nav-item @(currentPage == "backtest" ? "active" : "")"><i class="fas fa-flask"></i><span>백테스트</span></a></li>
					<li><a href="/Stock/DailyPrices" class="nav-item @(currentPage == "dailyprices" ? "active" : "")"><i class="fas fa-database"></i><span>일봉 수집</span></a></li>
					<li class="nav-divider"></li>
					<li><a href="/Stock/Glossary" class="nav-item @(currentPage == "glossary" ? "active" : "")"><i class="fas fa-book"></i><span>용어 사전</span></a></li>
				</ul>
			</nav>

			<div class="sidebar-system-info">
				<div class="system-info-title">
					<i class="fas fa-info-circle"></i>
					<span>System Info</span>
				</div>
				<div class="system-info-item">
					<span class="system-info-label">Version</span>
					<span class="system-info-value">v@(ViewBag.CacheVersion)</span>
				</div>
			</div>

			<div class="sidebar-footer">
				<a href="#" id="btnLogout" class="btn-logout">
					<i class="fas fa-sign-out-alt me-2"></i>로그아웃
				</a>
			</div>
		</aside>

		<!-- 메인 콘텐츠 -->
		<main class="main-content" id="mainContent">
			<header class="top-bar">
				<button class="menu-toggle" id="menuToggle">
					<i class="fas fa-bars"></i>
				</button>
				<h2 class="page-title" id="pageTitle">@ViewBag.PageTitle</h2>
			</header>

			@RenderBody()
		</main>
	</div>

	<!-- 삭제 확인 모달 -->
	<div class="stock-modal" id="deleteModal" style="display:none;">
		<div class="stock-modal-box">
			<i class="fas fa-exclamation-triangle warning-icon"></i>
			<p id="deleteMessage">정말 삭제하시겠습니까?</p>
			<div class="modal-actions">
				<button class="btn-modal-cancel" id="deleteModalCancel">취소</button>
				<button class="btn-modal-delete" id="deleteModalConfirm">삭제</button>
			</div>
		</div>
	</div>

	<!-- 로그아웃 확인 모달 -->
	<div class="stock-modal" id="logoutModal" style="display:none;">
		<div class="stock-modal-box">
			<i class="fas fa-sign-out-alt" style="font-size: 48px; color: var(--primary-light); margin-bottom: 16px;"></i>
			<p>로그아웃 하시겠습니까?</p>
			<div class="modal-actions">
				<button class="btn-modal-cancel" id="logoutCancel">취소</button>
				<button class="btn-modal-confirm" id="logoutConfirm">로그아웃</button>
			</div>
		</div>
	</div>

	<!-- 범용 알림/확인 모달 -->
	<div class="stock-modal" id="commonModal" style="display:none;">
		<div class="stock-modal-box">
			<i id="commonModalIcon" class="fas fa-info-circle" style="font-size: 48px; color: var(--primary-light); margin-bottom: 16px;"></i>
			<p id="commonModalMessage"></p>
			<p id="commonModalSub" style="font-size: 13px; color: var(--text-muted); margin-top: 8px; display:none;"></p>
			<div class="modal-actions">
				<button class="btn-modal-cancel" id="commonModalCancel" style="display:none;">취소</button>
				<button class="btn-modal-confirm" id="commonModalConfirm">확인</button>
			</div>
		</div>
	</div>


</body>
</html>
